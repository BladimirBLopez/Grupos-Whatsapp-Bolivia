{
  "functions": {
    "api/grupos.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/login.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/categorias.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/grupos",
      "destination": "/api/grupos.js"
    },
    {
      "source": "/api/login",
      "destination": "/api/login.js"
    },
    {
      "source": "/api/categorias",
      "destination": "/api/categorias.js"
    }
  ]
}